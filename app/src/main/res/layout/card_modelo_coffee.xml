<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="300dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/idTituloCoffee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:gravity="center_horizontal"
            android:text="Título"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="normal" />

        <ImageView
            android:id="@+id/imgCardCoffee"
            android:layout_width="150dp"
            android:layout_height="100dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="40dp"
            android:src="@color/black" />

        <TextView
            android:id="@+id/descCardCoffee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/imgCardCoffee"
            android:layout_margin="15dp"
            android:gravity="center_horizontal"
            android:text="Descrição: "
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="normal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/descCardCoffee"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iconCardStarCoffee"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginLeft="20dp"
                android:src="@drawable/baseline_star_border" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="4,5"
                android:textColor="@color/black"
                android:textSize="12sp" />

            <ImageView
                android:layout_width="30dp"
                android:layout_height="29dp"
                android:id="@+id/iconCardFavoriteCoffee"
                android:src="@drawable/baseline_favorite"
                android:layout_marginLeft="55dp"/>

            <ImageView
                android:layout_width="30dp"
                android:layout_height="29dp"
                android:id="@+id/iconCardShareCoffee"
                android:src="@drawable/baseline_share"
                android:layout_marginLeft="5dp"/>

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>